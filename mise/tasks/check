#!/usr/bin/env bash
#MISE description="Validate organization defaults and public-repository safety"
set -euo pipefail

test -f profile/README.md
test -f SECURITY.md
test -f SUPPORT.md
test -f .github/ISSUE_TEMPLATE/config.yml

if grep -RIE \
  '(BEGIN (RSA|OPENSSH|EC) PRIVATE KEY|ghp_[A-Za-z0-9]{20,}|sk_live_[A-Za-z0-9]+)' \
  . --exclude-dir=.git; then
  echo 'Possible secret found.'
  exit 1
fi
